				<!-- start content -->
				<div id="mw-content-text" class="mw-body-content mw-content-ltr" lang="en" dir="ltr"><div class="mw-parser-output"><div class="mainpage-background-wrapper">
<div class="mainpage-banner">
<p>Welcome to the official <span><a href="/wiki/Guild_Wars_2" title="Guild Wars 2"><img alt="Guild Wars 2" src="/images/thumb/4/45/Main_page_GW2_%28Secrets_of_the_Obscure%29.png/122px-Main_page_GW2_%28Secrets_of_the_Obscure%29.png" decoding="async" width="122" height="20" srcset="/images/thumb/4/45/Main_page_GW2_%28Secrets_of_the_Obscure%29.png/182px-Main_page_GW2_%28Secrets_of_the_Obscure%29.png 1.5x, /images/thumb/4/45/Main_page_GW2_%28Secrets_of_the_Obscure%29.png/243px-Main_page_GW2_%28Secrets_of_the_Obscure%29.png 2x" data-file-width="303" data-file-height="50" /></a></span> Wiki, the comprehensive reference written and maintained by the players.</p>
</div>
<div id="mainpage-content" class="mainpage-cell-wrapper">
<div class="mainpage-cell mainpage-cell-double">
<h2><span id="Current_release:_.E2.80.9CRaids_and_Wardrobe.E2.80.9D"></span><span class="mw-headline" id="Current_release:_“Raids_and_Wardrobe”">Current release: “<a href="/wiki/Raids_and_Wardrobe" title="Raids and Wardrobe">Raids and Wardrobe</a>”</span></h2>
<div class="mainpage-featured-images nomobile center"><a href="/wiki/Raids_and_Wardrobe" title="Raids and Wardrobe"><img alt="Raids and Wardrobe.jpg" src="/images/thumb/4/49/Raids_and_Wardrobe.jpg/550px-Raids_and_Wardrobe.jpg" decoding="async" width="550" height="187" srcset="/images/thumb/4/49/Raids_and_Wardrobe.jpg/825px-Raids_and_Wardrobe.jpg 1.5x, /images/thumb/4/49/Raids_and_Wardrobe.jpg/1100px-Raids_and_Wardrobe.jpg 2x" data-file-width="1570" data-file-height="535" /></a></div>
<div class="mainpage-featured-images mobileonly center"><a href="/wiki/Raids_and_Wardrobe" title="Raids and Wardrobe"><img alt="Raids and Wardrobe.jpg" src="/images/thumb/4/49/Raids_and_Wardrobe.jpg/550px-Raids_and_Wardrobe.jpg" decoding="async" width="550" height="187" srcset="/images/thumb/4/49/Raids_and_Wardrobe.jpg/825px-Raids_and_Wardrobe.jpg 1.5x, /images/thumb/4/49/Raids_and_Wardrobe.jpg/1100px-Raids_and_Wardrobe.jpg 2x" data-file-width="1570" data-file-height="535" /></a></div>
<p>Today we're launching the new quarterly <a href="/wiki/Raids_and_Wardrobe" title="Raids and Wardrobe">Raids and Wardrobe</a> update. This update unifies <a href="/wiki/Strike_Mission" title="Strike Mission">Strike Missions</a> and <a href="/wiki/Raid" title="Raid">Raids</a>, introduces a single Raids interface window, adds <a href="/wiki/Fashion_Template" class="mw-redirect" title="Fashion Template">Fashion Templates</a>, and more.
</p><p>As the <a href="/wiki/Tyrian_Alliance" title="Tyrian Alliance">Tyrian Alliance</a> determine their next movements against <a href="/wiki/Vloxx" class="mw-redirect" title="Vloxx">Vloxx</a> and the <a href="/wiki/Inquest" title="Inquest">Inquest</a>, the commanders and wayfinders of <a href="/wiki/Tyria_(world)" title="Tyria (world)">Tyria</a> turn their eyes to the menacing threats that linger in shadow... Challenge <a href="/wiki/Kela,_Seneschal_of_Waves" title="Kela, Seneschal of Waves">Kela, Seneschal of Waves</a>, and confront her in the new <a href="/wiki/Guardian%27s_Glade" title="Guardian&#39;s Glade">Guardian's Glade</a> raid.
</p>
<dl><dt><a href="/wiki/Raids_and_Wardrobe" title="Raids and Wardrobe">LEARN MORE</a></dt></dl>
</div>
<div class="mainpage-cell">
<h2><span id="News_.26_updates"></span><span class="mw-headline" id="News_&amp;_updates">News &amp; updates</span></h2>
<dl><dt>Current special event</dt>
<dd>▪&#160;<a href="/wiki/World_Boss_Rush" title="World Boss Rush">World Boss Rush</a> - March&#160;17-24,&#160;2026</dd>
<dt>Current game status</dt>
<dd>▪&#160;<a href="/wiki/Game_updates" title="Game updates">Game updates</a> - <a href="/wiki/Game_updates/2026-03-19" title="Game updates/2026-03-19">Thursday, 19 March 2026</a></dd>
<dd>▪&#160;<a href="/wiki/Upcoming_changes_and_features" title="Upcoming changes and features">Upcoming changes and features</a></dd>
<dd>▪&#160;<a href="/wiki/Release" title="Release">Releases</a> ▪&#160;<a href="/wiki/Release_calendar" title="Release calendar">Release calendar</a></dd>
<dd>▪&#160;<a href="/wiki/Event_timers" title="Event timers">Event timers</a> ▪&#160;<a href="/wiki/Server_reset" title="Server reset">Server reset</a></dd></dl>
<div id="mainpagenews" style="position:relative;">
<script>
(function() {

function getChild(xmlElement, tag) {
	if (xmlElement) {
		for (let i=0;i < xmlElement.childNodes.length;i++) {
			let elem = xmlElement.childNodes[i];
			if (elem.tagName === tag) {
				return elem;
			}
		}
	}
	return undefined;
}
function getChildren(xmlElement, tag) {
	let childElements = [];
	if (xmlElement) {
		for (let i=0;i < xmlElement.childNodes.length;i++) {
			let elem = xmlElement.childNodes[i];
			if (elem.tagName === tag) {
				childElements.push(elem);
			}
		}
	}
	return childElements;
}

let allowedProtocols = [
	"https"
].map(ap => ap + ":");
let allowedHosts = [
	"www.guildwars2.com",
	"en-forum.guildwars2.com"
];
function isAllowedLink(link) {
	try {
		let url = new URL(link);
		return allowedProtocols.includes(url.protocol)
			&& allowedHosts.includes(url.hostname);
	} catch {
		return false;
	}
}

let options = JSON.parse('{    \"count\": 10,    \"min\": 3,    \"add\": [    ]}');

function addList(target, newsData, heightReference) {
	if (window.getComputedStyle(heightReference, null).boxSizing !== "border-box") {
		setTimeout(function() {
			addList(target, newsData, heightReference);
		}, 1000/4);
		return;
	}
	let initialHeight = heightReference.clientHeight;
	let dl = document.createElement("dl");
	target.appendChild(dl);
	let previousDateHeading = undefined;
	let count = options.count || 10;
	let min = options.min || 3;
	let i = 0;
	for (;i < newsData.length && i !== count && (heightReference.clientHeight === initialHeight || i < min);i++) {
		let news = newsData[i];
		let currentDateHeading = news.date + (news.sticky ? " \u2605" : "");
		if (currentDateHeading !== previousDateHeading) {
			previousDateHeading = currentDateHeading;
			
			let dt = document.createElement("dt");
			dt.textContent = currentDateHeading;
			dl.appendChild(dt);
		}
		if (news.link && news.title) {
			let dd = document.createElement("dd");
			let bulletNbsp = document.createTextNode("\u25AA\u00A0");
			dd.appendChild(bulletNbsp);
			
			let a = document.createElement("a");
			a.textContent = news.title;
			a.classList.add("external");
			a.classList.add("text");
			a.rel = "nofollow";
			a.href = news.link;
			if (news.description) {
				a.title = news.description;
			}
			dd.appendChild(a);
			
			dl.appendChild(dd);
		}
	}
	let addedAtMostTheMinimumQuantity = i <= min;
	if (heightReference.clientHeight !== initialHeight && !addedAtMostTheMinimumQuantity) {
		dl.removeChild(dl.lastChild);
		switch (dl.lastChild.tagName.toLowerCase()) {
		case "dt":
			dl.removeChild(dl.lastChild);
			break;
		case "dd":
			break;
		default:
			console.error("Widget:News | Unexpected tag name \"" + dl.lastChild.tagName + "\".");
			break;
		}
	}
}
let request = new XMLHttpRequest();
request.addEventListener("error", function () {
	console.error("Widget:News | Could not retrieve the current news from the rss feed.", request.status + " " + request.statusText);
});
request.addEventListener("load", function () {
	console.assert(request.readyState === XMLHttpRequest.DONE, request.readyState);
	if (request.status !== 200) {
		console.error("Widget:News | Could not retrieve the current news from the rss feed.", request.status + " " + request.statusText);
		return;
	}
	let response = request.responseXML;
	let rss = getChild(response, "rss");
	let channel = getChild(rss, "channel");
	let items = getChildren(channel, "item");
	// Only include items with the News category.
	items = items.filter(function(item) {
		let categories = getChildren(item, "category");
		return categories.filter(function(category) {
			return category.textContent === "News";
		}).length === 1;
	});
	let monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
	let newsData = items.map(function(item) {
		let url;
		try {
			url = new URL(getChild(item, "link").textContent);
		} catch {
			return null;
		}
		let pubDate = new Date(getChild(item, "pubDate").textContent);
		
		let news = {};
		news.title = getChild(item, "title").textContent;
		url.search = "";
		news.link = url.href;
		news.date = monthNames[pubDate.getUTCMonth()] + " " + pubDate.getUTCDate() + ", " + pubDate.getUTCFullYear();
		let categories = getChildren(item, "category");
		news.sticky = categories.filter(function(category) {
			return category.textContent === "Sticky";
		}).length === 1;
		let description = getChild(item, "description").textContent;
		let i = description.indexOf("<");
		if (i !== -1) {
			description = description.substring(0, i);
		}
		news.description = description;
		return news;
	}).filter(news => news);
	// Add entries from the options object.
	if (options.add) {
		for (let i=0;i < options.add.length;i++) {
			let toAdd = options.add[i];
			if (toAdd.text && toAdd.link && toAdd.date) {
				// Only allow https links to known hosts.
				if (isAllowedLink(toAdd.link)) {
					let news = {};
					news.title = toAdd.text;
					news.link = toAdd.link;
					news.date = toAdd.date;
					news.sticky = typeof toAdd.sticky === "boolean" ? toAdd.sticky : false;
					newsData.push(news);
				}
			}
		}
	}
	// Hide entries specified in the options object.
	if (options.hide) {
		newsData = newsData.filter(function(news) {
			return options.hide.indexOf(news.title) === -1;
		});
	}
	// Remove non https links and links to unknown hosts.
	newsData = newsData.filter(function(news) {
		return isAllowedLink(news.link);
	});
	// Sort entries by date.
	let pattern = new RegExp("^(" + monthNames.join("|") + ")[ ]{1}([0-9]{1,2})[,]{1}[ ]{1}([0-9]{4})$");
	newsData.sort(function(a, b) {
		let matchA = pattern.exec(a.date);
		let matchB = pattern.exec(b.date);
		if (!matchA && !matchB) {
			return 0;
		}
		return !matchA - !matchB
			|| parseInt(matchB[3], 10) - parseInt(matchA[3], 10)
			|| monthNames.indexOf(matchB[1]) - monthNames.indexOf(matchA[1])
			|| parseInt(matchB[2], 10) - parseInt(matchA[2], 10);
	});
	// Sort sticky news to top.
	newsData.sort(function(a, b) {
		return b.sticky - a.sticky;
	});
	let target = document.getElementById("mainpagenews");
	if (target) {
		addList(target, newsData, target.parentNode);
	} else {
		console.error("Widget:News | No target element with #mainpagenews found.");
	}
});
request.open("GET", "https://www.guildwars2.com/en/feed/", true);
request.send();

})();
</script><div id="newseditlink" class="plainlinks" style="font-size: 0.8em; font-style: italic; position:absolute; right:0; top:0;"><a rel="nofollow" class="external text" href="//wiki.guildwars2.com/index.php?title=Template:News&amp;action=edit">Edit</a></div></div>
</div>
